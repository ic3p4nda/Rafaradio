{
  "name": "mineradio-clone",
  "version": "0.1.0",
  "description": "Custom visual music player, inspired by Mineradio",
  "main": "src/main.js",
  "scripts": {
    "start": "node start.js",
    "dev": "node start.js",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.mineradio.player",
    "productName": "MineRadioPlayer",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "express": "^5.2.1",
    "music-metadata": "^11.13.0",
    "three": "^0.185.1",
    "yt-dlp-wrap": "^2.3.12",
    "ytmusic-api": "^5.3.1"
  },
  "allowScripts": {
    "electron@31.7.7": true,
    "@biomejs/biome@1.8.3": true,
    "electron-winstaller@5.4.0": true
  }
}
